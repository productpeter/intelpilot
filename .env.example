NODE_ENV=development
PORT=3000
ADMIN_TOKEN=change_me_long_random

MONGODB_URI="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/intelpilot?retryWrites=true&w=majority"
MONGODB_DB=intelpilot

TABSTACK_API_KEY=
TABSTACK_BASE_URL="https://api.tabstack.ai"

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"
OPENAI_EMBEDDING_DIM=3072

SCAN_CRON="0 8 * * *"

R2_BUCKET=intelpilot-snapshots
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT="https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_REGION=auto
